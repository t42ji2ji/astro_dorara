---
import { Image } from 'astro:assets'
import type { Post } from '~/types'

interface Props {
  post: Post
}

const { post } = Astro.props
const banner = post.data.banner

function getPreviewContent(post: Post): string {
  let body = post.body || ''

  body = body.replace(/^import\s+.*$/gm, '')
  body = body.replace(/^export\s+.*$/gm, '')
  body = body.replace(/<[A-Z][a-zA-Z]*[^>]*\/>/g, '')
  body = body.replace(/<[A-Z][a-zA-Z]*[^>]*>[\s\S]*?<\/[A-Z][a-zA-Z]*>/g, '')
  body = body.replace(/<[^>]+>/g, '')
  body = body.replace(/^---[\s\S]*?---/m, '')
  body = body.replace(/^#{1,6}\s+.*$/gm, '')
  body = body.replace(/^>\s+.*$/gm, '')
  body = body.replace(/^---+$/gm, '')
  body = body.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  body = body.replace(/\*\*([^*]+)\*\*/g, '$1')
  body = body.replace(/\*([^*]+)\*/g, '$1')
  body = body.replace(/`([^`]+)`/g, '$1')

  const cleaned = body
    .split(/\n{2,}/)
    .map((p) => p.replace(/\s+/g, ' ').trim())
    .filter((p) => p.length > 0)
    .join('\n\n')

  const trimmed = cleaned.slice(0, 200)
  return trimmed + (cleaned.length > 200 ? '...' : '')
}

const previewContent = getPreviewContent(post)
---

<div class="preview-card not-prose">
  {
    banner && (
      <div class="preview-thumbnail">
        <Image src={banner} alt={post.data.title} class="w-full h-full object-cover" />
      </div>
    )
  }
  <p class="preview-text">{previewContent}</p>
</div>

<style>
  .preview-card {
    display: none;
    position: absolute;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 0.75rem;
    margin-top: 0.5rem;
    background: #f5f5f4;
    border: 1px solid #e7e5e4;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .preview-card {
    background: #292524;
    border-color: #44403c;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .preview-thumbnail {
    width: 100%;
    height: 120px;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .preview-thumbnail img {
    margin: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-text {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #78716c;
    white-space: pre-line;
  }

  @media (min-width: 768px) {
    .preview-card {
      display: block;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
    }

    :global(.post-item-wrapper:hover) .preview-card {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>
